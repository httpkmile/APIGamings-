    "def get_all_genres():\n",
    "    games = get_all_games()\n",
    "    if not games:\n",
    "        return []\n",
    "    \n",
    "    genres = set()\n",
    "    for game in games:\n",
    "        genres.add(game['genre'])\n",
    "    return sorted(list(genres))\n",
    "\n",
    "# Testar a função\n",
    "genres = get_all_genres()\n",
    "print(f\"Total genres: {len(genres)}\")\n",
    "print(\"Available genres:\")\n",
    "for i, genre in enumerate(genres[:10], 1):\n",
    "    print(f\"{i}. {genre}\")\n",
    "if len(genres) \u003e 10:\n",
    "    print(f\"... and {len(genres) - 10} more genres\")"
   ]
